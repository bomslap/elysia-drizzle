{
  "name": "elysia-drizzle",
  "version": "1.0.50",
  "scripts": {
    "start": "./server",
    "dev": "bun --env-file=.env.local run --watch src/index.ts",
    "test": "bun --env-file=.env.local test",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/index.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "elysia": "latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.9"
  },
  "module": "src/index.js"
}